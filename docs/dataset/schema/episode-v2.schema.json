{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://magrathea-pki.local/schema/episode-v2.schema.json",
  "title": "Magrathea PKI Dataset Episode V2",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "episodeId",
    "provenance",
    "environment",
    "task",
    "admission",
    "rawObservableEvents",
    "patches",
    "verification",
    "termination",
    "contextMetrics",
    "curation",
    "artifacts",
    "resumeCapsule"
  ],
  "properties": {
    "schemaVersion": {
      "const": "2.0"
    },
    "episodeId": {
      "type": "string",
      "pattern": "^[0-9]{4}(-[a-z0-9]+)*$"
    },
    "parentEpisodeId": {
      "type": [
        "string",
        "null"
      ]
    },
    "continuationId": {
      "type": [
        "string",
        "null"
      ]
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "captureMode",
        "promptVersion",
        "toolRegistryVersion",
        "initialCommit",
        "initialTree",
        "finalCommit",
        "finalTree",
        "workflow",
        "agent",
        "javaspec"
      ],
      "properties": {
        "captureMode": {
          "enum": [
            "RAW_EVENT_STREAM",
            "RECONSTRUCTED"
          ]
        },
        "promptVersion": {
          "type": "string",
          "minLength": 1
        },
        "toolRegistryVersion": {
          "type": "string",
          "minLength": 1
        },
        "initialCommit": {
          "type": "string",
          "minLength": 1
        },
        "initialTree": {
          "type": "string",
          "minLength": 1
        },
        "finalCommit": {
          "type": [
            "string",
            "null"
          ]
        },
        "finalTree": {
          "type": [
            "string",
            "null"
          ]
        },
        "workflow": {
          "type": "string",
          "minLength": 1
        },
        "agent": {
          "type": "string",
          "minLength": 1
        },
        "effectiveModel": {
          "type": [
            "string",
            "null"
          ]
        },
        "javaspec": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "version",
            "commit",
            "fingerprint"
          ],
          "properties": {
            "version": {
              "type": [
                "string",
                "null"
              ]
            },
            "commit": {
              "type": [
                "string",
                "null"
              ]
            },
            "fingerprint": {
              "type": [
                "string",
                "null"
              ]
            }
          }
        }
      }
    },
    "environment": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "os",
        "javaVersion",
        "buildTool",
        "repositoryStatus"
      ],
      "properties": {
        "os": {
          "type": [
            "string",
            "null"
          ]
        },
        "javaVersion": {
          "type": [
            "string",
            "null"
          ]
        },
        "buildTool": {
          "type": [
            "string",
            "null"
          ]
        },
        "repositoryStatus": {
          "type": [
            "string",
            "null"
          ]
        },
        "variables": {
          "type": "object",
          "additionalProperties": {
            "type": [
              "string",
              "null"
            ]
          }
        }
      }
    },
    "task": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "userRequest",
        "requirements",
        "allowedFiles"
      ],
      "properties": {
        "userRequest": {
          "type": "string"
        },
        "requirements": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "requirementIds": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "scenarioIds": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "allowedFiles": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "admission": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "decision",
        "reason",
        "checks"
      ],
      "properties": {
        "decision": {
          "enum": [
            "ACCEPTED",
            "REJECTED",
            "QUARANTINED"
          ]
        },
        "reason": {
          "type": "string"
        },
        "checks": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/check"
          }
        }
      }
    },
    "rawObservableEvents": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/observableEvent"
      }
    },
    "patches": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/patchReference"
      }
    },
    "verification": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "commands",
        "outcome",
        "evidence"
      ],
      "properties": {
        "commands": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/commandResult"
          }
        },
        "outcome": {
          "enum": [
            "NOT_RUN",
            "FAILED",
            "PASSED",
            "PARTIAL"
          ]
        },
        "evidence": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/artifactReference"
          }
        }
      }
    },
    "termination": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "suspectedOwner",
        "summary"
      ],
      "properties": {
        "type": {
          "enum": [
            "VERIFIED_SUCCESS",
            "FRAMEWORK_INCOHERENCE",
            "UNSUPPORTED_JAVA_CONSTRUCT",
            "SPECIFICATION_AMBIGUITY",
            "DOMAIN_MODEL_INCONSISTENCY",
            "MODEL_TOOL_ERROR",
            "MODEL_REASONING_ERROR",
            "BASELINE_FAILURE",
            "BUILD_ENVIRONMENT_FAILURE",
            "QUALITY_GATE_FAILURE",
            "SECURITY_RISK",
            "REGRESSION_DETECTED",
            "UNAUTHORIZED_FILE_CHANGE",
            "CONTEXT_LIMIT_REACHED",
            "HUMAN_DECISION_REQUIRED",
            "CHECKPOINT"
          ]
        },
        "suspectedOwner": {
          "enum": [
            "JAVASPEC",
            "SPEC_DRIVEN",
            "STORY_DRIVEN",
            "DATASET_WRITER",
            "SPECIFICATION",
            "DOMAIN_DESIGN",
            "PROJECT",
            "BUILD_ENVIRONMENT",
            "TOOLING",
            "UNKNOWN"
          ]
        },
        "summary": {
          "type": "string"
        }
      }
    },
    "contextMetrics": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "metricCollectionStatus",
        "maximumContextTokens",
        "peakContextTokens",
        "totalInputTokens",
        "cachedInputTokens",
        "outputTokens",
        "uniqueSourceBytesRead",
        "repeatedSourceBytesRead",
        "toolOutputBytesPresentedToModel",
        "compactionCount",
        "iterationCount"
      ],
      "properties": {
        "metricCollectionStatus": {
          "enum": [
            "AVAILABLE",
            "PARTIAL",
            "UNAVAILABLE"
          ]
        },
        "maximumContextTokens": {
          "$ref": "#/$defs/nonNegativeIntegerOrNull"
        },
        "peakContextTokens": {
          "$ref": "#/$defs/nonNegativeIntegerOrNull"
        },
        "totalInputTokens": {
          "$ref": "#/$defs/nonNegativeIntegerOrNull"
        },
        "cachedInputTokens": {
          "$ref": "#/$defs/nonNegativeIntegerOrNull"
        },
        "outputTokens": {
          "$ref": "#/$defs/nonNegativeIntegerOrNull"
        },
        "uniqueSourceBytesRead": {
          "$ref": "#/$defs/nonNegativeIntegerOrNull"
        },
        "repeatedSourceBytesRead": {
          "$ref": "#/$defs/nonNegativeIntegerOrNull"
        },
        "toolOutputBytesPresentedToModel": {
          "$ref": "#/$defs/nonNegativeIntegerOrNull"
        },
        "compactionCount": {
          "$ref": "#/$defs/nonNegativeIntegerOrNull"
        },
        "iterationCount": {
          "$ref": "#/$defs/nonNegativeIntegerOrNull"
        }
      }
    },
    "curation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "reviewers",
        "knownIssues",
        "sftEligibility",
        "evaluationEligibility"
      ],
      "properties": {
        "status": {
          "enum": [
            "RAW_UNREVIEWED",
            "REPLAY_VERIFIED",
            "BEHAVIOR_VERIFIED",
            "CURATED_SFT_CANDIDATE",
            "CURATED_SFT",
            "CURATED_PREFERENCE",
            "EVALUATION_CASE",
            "FRAMEWORK_FAILURE",
            "MODEL_FAILURE",
            "SPECIFICATION_FAILURE",
            "QUALITY_REJECTED",
            "SECURITY_REJECTED",
            "REPLAY_FAILED"
          ]
        },
        "reviewers": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "knownIssues": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "sftEligibility": {
          "$ref": "#/$defs/statusWithReason"
        },
        "evaluationEligibility": {
          "$ref": "#/$defs/statusWithReason"
        }
      }
    },
    "artifacts": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/artifactReference"
      }
    },
    "resumeCapsule": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "currentCommit",
        "currentTree",
        "requirementIds",
        "scenarioIds",
        "currentBehavior",
        "owningAgent",
        "fileHashes",
        "lastVerifiedResult",
        "lastFailureOrStop",
        "unresolvedWork",
        "allowedFiles",
        "javaspecFingerprint",
        "nextPermittedAction"
      ],
      "properties": {
        "currentCommit": {
          "type": [
            "string",
            "null"
          ]
        },
        "currentTree": {
          "type": [
            "string",
            "null"
          ]
        },
        "requirementIds": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "scenarioIds": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "currentBehavior": {
          "type": "string"
        },
        "owningAgent": {
          "type": "string"
        },
        "fileHashes": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/fileHash"
          }
        },
        "lastVerifiedResult": {
          "type": [
            "string",
            "null"
          ]
        },
        "lastFailureOrStop": {
          "type": [
            "string",
            "null"
          ]
        },
        "unresolvedWork": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "allowedFiles": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "javaspecFingerprint": {
          "type": [
            "string",
            "null"
          ]
        },
        "nextPermittedAction": {
          "type": "string"
        }
      }
    }
  },
  "$defs": {
    "nonNegativeIntegerOrNull": {
      "type": [
        "integer",
        "null"
      ],
      "minimum": 0
    },
    "check": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "status",
        "evidence"
      ],
      "properties": {
        "name": {
          "type": "string"
        },
        "status": {
          "enum": [
            "PASS",
            "FAIL",
            "WARN",
            "NOT_APPLICABLE"
          ]
        },
        "evidence": {
          "type": "string"
        }
      }
    },
    "observableEvent": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "sequence",
        "eventType",
        "summary"
      ],
      "properties": {
        "sequence": {
          "type": "integer",
          "minimum": 0
        },
        "timestamp": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time"
        },
        "eventType": {
          "type": "string"
        },
        "actor": {
          "type": [
            "string",
            "null"
          ]
        },
        "toolName": {
          "type": [
            "string",
            "null"
          ]
        },
        "arguments": {
          "type": [
            "object",
            "array",
            "string",
            "null"
          ]
        },
        "result": {
          "type": [
            "object",
            "array",
            "string",
            "null"
          ]
        },
        "exitCode": {
          "type": [
            "integer",
            "null"
          ]
        },
        "summary": {
          "type": "string"
        }
      }
    },
    "patchReference": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "sha256",
        "byteSize",
        "description"
      ],
      "properties": {
        "path": {
          "type": "string"
        },
        "sha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "byteSize": {
          "type": "integer",
          "minimum": 0
        },
        "description": {
          "type": "string"
        }
      }
    },
    "commandResult": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "command",
        "exitCode",
        "summary"
      ],
      "properties": {
        "command": {
          "type": "string"
        },
        "exitCode": {
          "type": "integer"
        },
        "stdoutArtifact": {
          "$ref": "#/$defs/artifactReference"
        },
        "stderrArtifact": {
          "$ref": "#/$defs/artifactReference"
        },
        "summary": {
          "type": "string"
        }
      }
    },
    "artifactReference": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "sha256",
        "mediaType",
        "byteSize"
      ],
      "properties": {
        "path": {
          "type": "string"
        },
        "sha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "mediaType": {
          "type": "string"
        },
        "byteSize": {
          "type": "integer",
          "minimum": 0
        },
        "description": {
          "type": "string"
        }
      }
    },
    "fileHash": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "sha256",
        "byteSize"
      ],
      "properties": {
        "path": {
          "type": "string"
        },
        "sha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "byteSize": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "statusWithReason": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "reason"
      ],
      "properties": {
        "status": {
          "type": "string"
        },
        "reason": {
          "type": "string"
        }
      }
    }
  }
}
