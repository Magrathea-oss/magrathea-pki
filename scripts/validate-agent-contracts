#!/usr/bin/env python3
import json
import pathlib
import sys

ROOT = pathlib.Path(__file__).resolve().parents[1]
SKILL = pathlib.Path('/home/paperboy/.pi/agent/skills/multi-agent')
AGENTS = {
    'spec-driven': SKILL / 'agents/spec-driven.md',
    'story-driven': SKILL / 'agents/story-driven.md',
    'dataset-writer': SKILL / 'agents/dataset-writer.md',
}
WORKFLOW = SKILL / 'workflows/bdd-java.md'
REGISTRY = SKILL / 'enforcement/packs/pi-java-multiagent/capability-registry.json'
failures = []

def require(cond, msg):
    if not cond:
        failures.append(msg)

def text(path):
    try:
        return path.read_text()
    except FileNotFoundError:
        failures.append(f'missing {path}')
        return ''

agent_text = {name: text(path) for name, path in AGENTS.items()}
for name, body in agent_text.items():
    require(f'name: {name}' in body, f'{name} identifier missing')
    require('Prompt version:' in body, f'{name} prompt version missing')
    require('exactly one method body' not in body.lower(), f'{name} contains obsolete one-method-body language')
    require('exactly one new implemented member' not in body.lower(), f'{name} contains obsolete generated-member-count language')

require('externally meaningful Java domain behavior' in agent_text['spec-driven'], 'spec-driven semantic behavior language missing')
require('pure-domain development agent' in agent_text['spec-driven'], 'spec-driven pure-domain role missing')
require('structured handoff' in agent_text['spec-driven'], 'spec-driven handoff language missing')
require('MULTI_AGENT_TRACE_ID' in agent_text['spec-driven'], 'spec-driven raw-capture gate missing')
require('javaspec' in agent_text['spec-driven'], 'spec-driven javaspec language missing')
require('application, scenario, adapter, and integration agent' in agent_text['story-driven'], 'story-driven role missing')
require('MISSING_DOMAIN_BEHAVIOR' in agent_text['story-driven'], 'story-driven missing-domain stop missing')
require('extract -> delegate -> response' in agent_text['story-driven'], 'story-driven thin-adapter contract missing')
require('independent dataset recorder' in agent_text['dataset-writer'], 'dataset-writer role missing')
require('must never directly alter implementation source' in agent_text['dataset-writer'], 'dataset-writer source-modification prohibition missing')
require('CURATED_SFT' in agent_text['dataset-writer'], 'dataset-writer curation language missing')
require('sealed trace path' in agent_text['dataset-writer'], 'dataset-writer sealed-trace requirement missing')

wf = text(WORKFLOW)
require('agent: story-driven' in wf and 'agent: dataset-writer' in wf, 'bdd-java workflow missing implementation/dataset agents')
require(wf.count('agent: dataset-writer') == 1, 'dataset-writer should be a direct planner child exactly once in bdd-java')
require('dataset-writer (validates sealed spec-driven javaspec trajectories only)' in wf, 'bdd-java sealed spec-driven javaspec routing missing')

registry = json.loads(text(REGISTRY) or '{}')
rules = registry.get('fileRules', [])
require(any(r.get('pattern') == 'docs/dataset/**' and r.get('owner') == 'dataset-writer' for r in rules), 'dataset file rule missing')
require(any(r.get('pattern') == 'docs/agent-workflow/artifacts/**' and r.get('owner') == 'dataset-writer' for r in rules), 'dataset artifact file rule missing')

agents_md = text(ROOT / 'AGENTS.md')
require('semantic atomicity' in agents_md, 'AGENTS.md semantic atomicity missing')
require('dataset-writer' in agents_md, 'AGENTS.md dataset-writer ownership missing')
require('Typed Stops and Handoffs' in agents_md, 'AGENTS.md typed stops section missing')
require('exactly one method body' not in agents_md.lower(), 'AGENTS.md contains obsolete one-method-body language')

if failures:
    print('validate-agent-contracts: FAIL')
    for failure in failures:
        print('-', failure)
    sys.exit(1)
print('validate-agent-contracts: PASS')
for name, path in AGENTS.items():
    print(f'{name}: {path}')
