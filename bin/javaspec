#!/usr/bin/env bash
# javaspec 1.0 RC launcher for the magrathea-pki project.
#
# The CLI artifact is resolved from Maven Central into a project-local cache.
# No javaspec checkout or host Maven repository is mounted, so clean dogfooding
# cannot accidentally consume locally built framework classes.
#
# Usage (from the module you want to operate on):
#   cd trust-engine-domain
#   ../bin/javaspec describe com.magrathea.trustengine.domain.kms.Key
#   ../bin/javaspec run --generate --compile --profile java21
set -euo pipefail

readonly image="${MAGRATHEA_BUILD_IMAGE:-localhost/magrathea-build:fedora42}"
readonly javaspec_version="${JAVASPEC_VERSION:-1.0.0-RC3}"
readonly project_root="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
readonly cache="${JAVASPEC_CACHE_DIR:-${project_root}/target/javaspec-remote-m2}"
readonly artifact="io.github.jvmspec:javaspec:${javaspec_version}"
readonly jar="/root/.m2/repository/io/github/jvmspec/javaspec/${javaspec_version}/javaspec-${javaspec_version}.jar"

mkdir -p "${cache}"

exec podman run --rm \
  -v "$(pwd)":/work \
  -v "${cache}":/root/.m2/repository \
  -w /work \
  -e "JAVASPEC_ARTIFACT=${artifact}" \
  -e "JAVASPEC_JAR=${jar}" \
  -e "JAVASPEC_VERSION=${javaspec_version}" \
  "${image}" \
  sh -ec 'printf "%s\n" "<project><modelVersion>4.0.0</modelVersion><groupId>dogfood</groupId><artifactId>javaspec-bootstrap</artifactId><version>1</version></project>" > /tmp/javaspec-bootstrap-pom.xml
           mvn -q -f /tmp/javaspec-bootstrap-pom.xml dependency:get -Dartifact="${JAVASPEC_ARTIFACT}" -Dtransitive=false
           if [ "${1:-}" = "--launcher-version" ]; then
             printf "%s\n" "${JAVASPEC_VERSION}"
             exit 0
           fi
           if [ "${1:-}" = "--launcher-fingerprint" ]; then
             printf "javaspec.launcher.version=%s\n" "${JAVASPEC_VERSION}"
             printf "javaspec.launcher.jar=%s\n" "${JAVASPEC_JAR}"
             printf "javaspec.launcher.sha256=%s\n" "$(sha256sum "${JAVASPEC_JAR}" | awk '\''{print $1}'\'')"
             exit 0
           fi
           exec java -cp "${JAVASPEC_JAR}" io.github.jvmspec.cli.Main "$@"' \
  javaspec "$@"
